<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Checkstyle ruleset for eat-club.
    Javadoc enforcement is deliberately omitted — selective Javadoc is fine.
-->
<module name="Checker">

    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>
    <property name="fileExtensions" value="java"/>

    <!-- Files must end with a newline -->
    <module name="NewlineAtEndOfFile"/>

    <!-- No tab characters anywhere in source -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <module name="TreeWalker">

        <!-- ── Imports ── -->
        <module name="AvoidStarImport"/>

        <!-- ── Naming conventions ── -->
        <module name="TypeName"/>
        <module name="MethodName"/>
        <module name="LocalVariableName"/>
        <module name="MemberName"/>
        <module name="StaticVariableName"/>
        <module name="ConstantName"/>
        <module name="ParameterName"/>
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- ── Space after keywords: if (, for (, while (, do, try, catch, finally, else ── -->
        <module name="WhitespaceAfter"/>

        <!-- ── Space before opening brace: ) { ── -->
        <module name="WhitespaceAround">
            <property name="tokens" value="LCURLY"/>
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
            <property name="allowEmptyLoops" value="true"/>
            <property name="allowEmptyLambdas" value="true"/>
        </module>

        <!-- ── No space after ( or before ): catches .method( arg) ── -->
        <module name="ParenPad"/>

        <!-- ── Braces required on all if/else/for/while/do blocks ── -->
        <module name="NeedBraces"/>

    </module>

    <!-- ── Max line length: 120 chars, imports and URLs excluded ── -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|.*https?://.*"/>
    </module>

</module>
