<?xml version="1.0" encoding="UTF-8"?>
<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.recipes</groupId>
        <artifactId>recipes-api</artifactId>
        <version>1.0.0</version>
    </parent>

    <artifactId>recipes-api-rest</artifactId>
    <name>recipes-api</name>
    <description>API layer — REST controllers, Lambda handler, OpenAPI spec. Produces the deployable fat JAR.
    </description>

    <dependencies>
        <!-- Internal: service layer (repository arrives transitively) -->
        <dependency>
            <groupId>com.recipes</groupId>
            <artifactId>recipes-service</artifactId>
        </dependency>

        <!-- Micronaut HTTP — required by micronaut-function-aws-api-proxy -->
        <dependency>
            <groupId>io.micronaut</groupId>
            <artifactId>micronaut-http</artifactId>
        </dependency>

        <!-- Micronaut Lambda API Gateway proxy — bridges API Gateway proxy events to Micronaut DI -->
        <dependency>
            <groupId>io.micronaut.aws</groupId>
            <artifactId>micronaut-function-aws-api-proxy</artifactId>
        </dependency>

        <!-- Jackson — JSON serialization / deserialization -->
        <dependency>
            <groupId>io.micronaut</groupId>
            <artifactId>micronaut-jackson-databind</artifactId>
        </dependency>

        <!-- Bean validation — @Valid, @NotNull, @NotBlank etc. on generated models -->
        <dependency>
            <groupId>io.micronaut.validation</groupId>
            <artifactId>micronaut-validation</artifactId>
        </dependency>

        <!-- AWS SDK v2 S3 — used by ImportRecipesHandler to download import files -->
        <dependency>
            <groupId>software.amazon.awssdk</groupId>
            <artifactId>s3</artifactId>
        </dependency>

        <!-- URL connection HTTP client — synchronous HTTP for Lambda (no Netty) -->
        <dependency>
            <groupId>software.amazon.awssdk</groupId>
            <artifactId>url-connection-client</artifactId>
        </dependency>

        <!-- Swagger annotations — required by OpenAPI-generated model classes -->
        <dependency>
            <groupId>io.swagger.core.v3</groupId>
            <artifactId>swagger-annotations</artifactId>
            <version>2.2.25</version>
        </dependency>

        <!-- Lombok — compile-time only -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <version>${lombok.version}</version>
            <optional>true</optional>
        </dependency>

        <!--
            Annotation processors declared as provided so Maven discovers them via the
            compile classpath using BOM-managed versions. This keeps the processor version
            consistent with the runtime version, avoiding NoSuchMethodError at compile time.
        -->
        <dependency>
            <groupId>io.micronaut</groupId>
            <artifactId>micronaut-inject-java</artifactId>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>io.micronaut.validation</groupId>
            <artifactId>micronaut-validation-processor</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Test -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!--
                Suppress compiler warnings for this module. Warnings originate from
                generated model classes (Lombok @Builder + field initializers) that
                we cannot modify. Checkstyle covers hand-written code quality.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <showWarnings>false</showWarnings>
                </configuration>
            </plugin>

            <!-- OpenAPI Generator — generates request/response model POJOs from the spec -->
            <plugin>
                <groupId>org.openapitools</groupId>
                <artifactId>openapi-generator-maven-plugin</artifactId>
                <version>${openapi-generator.version}</version>
                <executions>
                    <execution>
                        <id>generate-recipes-api</id>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <inputSpec>${project.basedir}/src/main/resources/openapi/openapi.yaml</inputSpec>

                            <!--
                                java-micronaut-server generates model POJOs from the spec.
                                API generation is disabled — handlers call the service layer directly.
                            -->
                            <generatorName>java-micronaut-server</generatorName>
                            <output>${project.build.directory}/generated-sources/openapi</output>
                            <apiPackage>com.recipes.api.generated.api</apiPackage>
                            <modelPackage>com.recipes.api.generated.model</modelPackage>

                            <generateApis>false</generateApis>
                            <generateSupportingFiles>false</generateSupportingFiles>
                            <generateApiTests>false</generateApiTests>
                            <generateModelTests>false</generateModelTests>
                            <generateApiDocumentation>false</generateApiDocumentation>
                            <generateModelDocumentation>false</generateModelDocumentation>

                            <configOptions>
                                <!--
                                    reactive=false: return plain types instead of Mono<T>.
                                    useTags=true: group by OpenAPI tag ("Recipes") for the class name.
                                -->
                                <reactive>false</reactive>
                                <useTags>true</useTags>
                                <serializationLibrary>jackson</serializationLibrary>
                                <openApiNullable>false</openApiNullable>
                                <hideGenerationTimestamp>true</hideGenerationTimestamp>
                                <useJakartaEe>true</useJakartaEe>
                                <!--
                                    The generator writes its own all-args constructor, so
                                    @AllArgsConstructor is omitted to avoid a duplicate.
                                    @NoArgsConstructor is added so Jackson can deserialize
                                    request bodies using the no-args constructor + setters.
                                    @Builder uses the generator's all-args constructor.
                                -->
                                <additionalModelTypeAnnotations>
                                    @lombok.Builder;
                                    @lombok.NoArgsConstructor
                                </additionalModelTypeAnnotations>
                            </configOptions>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Build Helper: add generated sources to compile classpath -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <version>3.6.0</version>
                <executions>
                    <execution>
                        <id>add-generated-sources</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>add-source</goal>
                        </goals>
                        <configuration>
                            <sources>
                                <source>${project.build.directory}/generated-sources/openapi/src/main/java</source>
                            </sources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!--
                Maven Shade Plugin — produces a flat uber JAR for Lambda deployment.

                Micronaut's DI metadata is generated at compile time into
                META-INF/micronaut/ rather than discovered at runtime via classpath
                scanning. This means we do NOT need the complex Spring auto-configuration
                transformers required in the Spring Boot version of this project.

                The only transformers needed are:
                - ServicesResourceTransformer: merges META-INF/services/* SPI registrations
                  (still used by Jackson and other SPI-based providers).
                - ManifestResourceTransformer: sets the Main-Class for local 'java -jar' use.

                Signed JAR entries are excluded to prevent SecurityException at runtime.
                Lombok is excluded — it is compile-time only.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.5.3</version>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <createDependencyReducedPom>false</createDependencyReducedPom>
                            <transformers>
                                <transformer
                                        implementation="org.apache.maven.plugins.shade.resource.ServicesResourceTransformer"/>
                            </transformers>
                            <filters>
                                <filter>
                                    <artifact>*:*</artifact>
                                    <excludes>
                                        <exclude>META-INF/*.SF</exclude>
                                        <exclude>META-INF/*.DSA</exclude>
                                        <exclude>META-INF/*.RSA</exclude>
                                    </excludes>
                                </filter>
                                <filter>
                                    <artifact>org.projectlombok:lombok</artifact>
                                    <excludes>
                                        <exclude>**</exclude>
                                    </excludes>
                                </filter>
                            </filters>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>


</project>
